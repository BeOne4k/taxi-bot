# ─── WhatsApp (Baileys) ───────────────────────────────────────
# No token needed — Baileys uses QR code pairing on first run.
# Session is stored in ./auth_info_baileys/


LOG_LEVEL=fatal

# ─── Anti-spam throttling (пауза между исходящими сообщениями) ─
# Случайная пауза между КАЖДЫМ отправленным сообщением, мс
MSG_MIN_DELAY_MS=1500
MSG_MAX_DELAY_MS=3500
# Имитация набора текста: мс на символ и потолок
MSG_TYPING_MS_PER_CHAR=30
MSG_TYPING_MAX_MS=3500

# ─── WeedeN REST API ──────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_API_TOKEN=your_api_token_here

# ─── Webhook ──────────────────────────────────────────────────
WEBHOOK_SECRET=your_strong_secret_here
WEBHOOK_PORT=8080
THANK_YOU_DELAY_SECONDS=600
RETENTION_DELAY_SECONDS=86400

# ─── AI Assistant (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI Help Assistant (Gemini) ───────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ─── Manager Notifications ────────────────────────────────────
# WhatsApp number in international format without +, e.g. 66812345678@s.whatsapp.net
MANAGER_WA_JID=66812345678@s.whatsapp.net
MANAGER_PHONE=+66812345678
MANAGER_WORK_START=10
MANAGER_WORK_END=18

# ─── External Links ───────────────────────────────────────────
SOCIALS_URL=https://your-socials-landing.com

# ─── Analytics (optional) ─────────────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret

# ─── Meta Ads Manager ─────────────────────────────────────────
META_ADS_PIXEL_ID=123...
META_ADS_ACCESS_TOKEN=EAA...

# ─── BotsAPI connection ───────────────────────────────────────
BOTS_API_URL=http://localhost:8000
BOTS_API_KEY=your_bots_api_key

# ─── Twilio SMS ───────────────────────────────────────────────
TWILIO_PHONE=+18...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=7b5d...
TWILIO_MESSAGING_SERVICE_SID=MG...
